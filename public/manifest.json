{
  "manifest_version": 3,
  "name": "SnapPaste",
  "version": "1.1",
  "description": "Snap your snippets, paste them instantly — with categories, placeholders, and file sync.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "SnapPaste",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "snappaste@extension",
      "strict_min_version": "109.0"
    }
  }
}
